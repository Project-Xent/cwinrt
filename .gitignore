# Build output
.xmake/
build/
.vs/
*.user

# Compiled artifacts (the generator + tests build these; never commit them)
*.obj
*.exe
*.lib
*.pdb
*.ilk
*.exp

# Generated impl-compile shards (regenerated by scripts/gen_header_compile_shards.ps1)
tests/conform/header_shards/compile_*.c
!tests/conform/header_shards/compile_smoke.c

# Local/machine-specific Claude settings (a shared .claude/settings.json may be committed)
.claude/settings.local.json

# Source backups / archives and scratch logs
*.zip
*.log

# NOTE: include/cwinrt/*.h and impl/*.impl.c ARE tracked (pre-generated cache the
# gates compile against); tests/golden/ IS tracked (the ABI baseline).
